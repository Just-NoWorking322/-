<Window x:Class="NurMarketKassa.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pos="clr-namespace:NurMarketKassa.Models.Pos"
        Title="Касса — Nur Market"
        Icon="pack://application:,,,/Assets/app-logo.png"
        Height="840" Width="1280"
        MinHeight="640" MinWidth="960"
        Background="#0A0A0A"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="DarkTb" TargetType="TextBox">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="CaretBrush" Value="#F3F4F6"/>
        </Style>
        <Style x:Key="HdrBtn" TargetType="Button">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#111827"
                BorderBrush="#374151"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0"
                       Source="pack://application:,,,/Assets/app-logo.png"
                       Width="44"
                       Height="44"
                       Margin="0,0,14,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Grid.Column="1"
                            Orientation="Vertical"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="UserTitleText"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#F9FAFB"/>
                    <TextBlock x:Name="BranchText"
                               FontSize="12"
                               Foreground="#9CA3AF"
                               Margin="0,2,0,0"/>
                    <TextBlock x:Name="ProfileStatusText"
                               FontSize="11"
                               Foreground="#9CA3AF"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Настройки"
                            Click="Settings_Click"
                            Style="{StaticResource HdrBtn}"
                            Margin="0,0,8,0"/>
                    <Button x:Name="PrintSelfCheckButton"
                            Content="Тест принтера"
                            Click="PrintSelfCheck_Click"
                            Style="{StaticResource HdrBtn}"
                            Margin="0,0,8,0"/>
                    <Button Content="Тест весов"
                            Click="ScaleTest_Click"
                            Style="{StaticResource HdrBtn}"
                            Margin="0,0,8,0"/>
                    <Button Content="Выйти"
                            Click="Logout_Click"
                            Padding="14,8"
                            FontSize="13"
                            Cursor="Hand"
                            Background="#374151"
                            Foreground="#F3F4F6"
                            BorderBrush="#4B5563"
                            BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="ShiftBannerBar"
                Grid.Row="1"
                Background="#FFFBEB"
                BorderBrush="#F59E0B"
                BorderThickness="0,0,0,1"
                Padding="12,10"
                Margin="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="ShiftStatusText"
                               TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#B45309"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="OfflineSaleButton"
                                Content="Оффлайн оплата"
                                Click="OfflineCheckout_Click"
                                Padding="10,6"
                                Margin="0,0,8,0"
                                Cursor="Hand"
                                Background="#422006"
                                Foreground="#FCD34D"
                                BorderBrush="#B45309"
                                BorderThickness="1"
                                ToolTip="Сохранить чек локально для выгрузки на сервер (без API checkout)"/>
                        <Button Content="Очередь офлайн"
                                Click="OfflineQueueInfo_Click"
                                Padding="10,6"
                                Cursor="Hand"
                                Background="#1F2937"
                                Foreground="#E5E7EB"
                                BorderBrush="#374151"
                                BorderThickness="1"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="12,0,0,0"
                            VerticalAlignment="Top">
                    <Button x:Name="OpenShiftButton"
                            Content="Открыть смену"
                            Click="OpenShift_Click"
                            Padding="10,6"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            Background="#1F2937"
                            Foreground="#F3F4F6"
                            BorderBrush="#374151"
                            BorderThickness="1"/>
                    <Button x:Name="CloseShiftButton"
                            Content="Закрыть смену"
                            Click="CloseShift_Click"
                            Padding="10,6"
                            IsEnabled="False"
                            Cursor="Hand"
                            Background="#1F2937"
                            Foreground="#F3F4F6"
                            BorderBrush="#374151"
                            BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="384"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="16,0,12,0"
                    Background="#161616"
                    BorderBrush="#333333"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ScaleStatusText"
                               Grid.Row="0"
                               FontSize="12"
                               Foreground="#9CA3AF"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CatalogSearchBox"
                                 Grid.Column="0"
                                 Margin="0,0,8,0"
                                 Padding="8,6"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 Style="{StaticResource DarkTb}"
                                 TextChanged="CatalogSearchBox_TextChanged"/>
                        <Button Grid.Column="1"
                                Content="Обновить каталог"
                                Click="RefreshCatalog_Click"
                                Padding="10,6"
                                Cursor="Hand"
                                Background="#374151"
                                Foreground="#F3F4F6"
                                BorderBrush="#4B5563"
                                BorderThickness="1"/>
                    </Grid>
                    <TabControl x:Name="CatalogTabs"
                                Grid.Row="2"
                                Grid.RowSpan="2"
                                Margin="0,0,0,0"
                                Background="#161616"
                                BorderBrush="#404040"
                                Foreground="#E5E7EB"
                                SelectionChanged="CatalogTabs_SelectionChanged">
                        <TabItem Header="Вес (кг)">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Padding="0,8,0,0">
                                <ItemsControl x:Name="CatalogItemsKg">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type pos:CatalogProductTileVm}">
                                            <Button Click="CatalogProduct_Click"
                                                    Padding="6"
                                                    Margin="3"
                                                    Width="118"
                                                    Cursor="Hand"
                                                    Background="#FAFAFA"
                                                    BorderBrush="#E5E7EB"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <Border Width="64"
                                                            Height="64"
                                                            Background="#EEF2FF"
                                                            CornerRadius="4"
                                                            HorizontalAlignment="Center">
                                                        <Image Width="60"
                                                               Height="60"
                                                               Stretch="Uniform"
                                                               Source="{Binding Thumb}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="38"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,6,0,0"/>
                                                    <TextBlock Text="{Binding PriceLine}"
                                                               FontSize="10"
                                                               Foreground="#9CA3AF"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Штучные">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Padding="0,8,0,0">
                                <ItemsControl x:Name="CatalogItemsPiece">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type pos:CatalogProductTileVm}">
                                            <Button Click="CatalogProduct_Click"
                                                    Padding="6"
                                                    Margin="3"
                                                    Width="118"
                                                    Cursor="Hand"
                                                    Background="#FAFAFA"
                                                    BorderBrush="#E5E7EB"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <Border Width="64"
                                                            Height="64"
                                                            Background="#ECFDF5"
                                                            CornerRadius="4"
                                                            HorizontalAlignment="Center">
                                                        <Image Width="60"
                                                               Height="60"
                                                               Stretch="Uniform"
                                                               Source="{Binding Thumb}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="38"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,6,0,0"/>
                                                    <TextBlock Text="{Binding PriceLine}"
                                                               FontSize="10"
                                                               Foreground="#9CA3AF"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border x:Name="SearchOverlayPanel"
                    Grid.Column="0"
                    Panel.ZIndex="10"
                    Margin="16,0,12,0"
                    Background="White"
                    BorderBrush="#F59E0B"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="12"
                    Visibility="Collapsed">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top"
                               x:Name="SearchOverlayTitle"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Margin="0,0,0,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="CatalogSearchItems">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type pos:CatalogProductTileVm}">
                                    <Button Click="CatalogProduct_Click"
                                            Padding="6"
                                            Margin="3"
                                            Width="118"
                                            Cursor="Hand"
                                            Background="#FFFBEB"
                                            BorderBrush="#FCD34D"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <Border Width="64"
                                                    Height="64"
                                                    Background="#FEF3C7"
                                                    CornerRadius="4"
                                                    HorizontalAlignment="Center">
                                                <Image Width="60"
                                                       Height="60"
                                                       Stretch="Uniform"
                                                       Source="{Binding Thumb}"/>
                                            </Border>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="38"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,6,0,0"/>
                                            <TextBlock Text="{Binding PriceLine}"
                                                       FontSize="10"
                                                       Foreground="#9CA3AF"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="0,0,16,0"
                    Background="#161616"
                    BorderBrush="#333333"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Корзина"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#F9FAFB"
                               Margin="0,0,0,8"/>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="StartSaleButton"
                                Content="Начать продажу"
                                Click="StartSale_Click"
                                Padding="12,8"
                                Margin="0,0,8,0"
                                Cursor="Hand"
                                Background="#F7D617"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Foreground="#111827"/>
                        <Button x:Name="RefreshCartButton"
                                Content="Обновить"
                                Click="RefreshCart_Click"
                                Padding="12,8"
                                IsEnabled="False"
                                Cursor="Hand"
                                Margin="0,0,8,0"
                                Background="#374151"
                                Foreground="#F3F4F6"
                                BorderBrush="#4B5563"
                                BorderThickness="1"/>
                        <Button x:Name="CheckoutButton"
                                Content="Оплатить"
                                Click="Checkout_Click"
                                Padding="12,8"
                                IsEnabled="False"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                Background="#10B981"
                                Foreground="White"
                                BorderThickness="0"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Отложить чек"
                                Click="DeferCart_Click"
                                Padding="10,7"
                                Margin="0,0,8,0"
                                Cursor="Hand"
                                Background="#4B5563"
                                Foreground="#F9FAFB"
                                BorderThickness="0"
                                ToolTip="Сохранить корзину и начать новую продажу"/>
                        <Button Content="Отложенные…"
                                Click="OpenDeferredCarts_Click"
                                Padding="10,7"
                                Cursor="Hand"
                                Background="#1F2937"
                                Foreground="#FCD34D"
                                BorderBrush="#B45309"
                                BorderThickness="1"
                                ToolTip="Загрузить одну или несколько отложенных корзин в текущий чек"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Скидка на чек"
                               FontSize="11"
                               Foreground="#9CA3AF"
                               Margin="0,0,0,4"/>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OrderDiscountPctBox"
                                 Grid.Column="0"
                                 Margin="0,0,4,0"
                                 Padding="6,4"
                                 Style="{StaticResource DarkTb}"
                                 ToolTip="Процент (только % или только сумма)"/>
                        <TextBlock Grid.Column="1"
                                   Text="%"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="#9CA3AF"/>
                        <TextBox x:Name="OrderDiscountSumBox"
                                 Grid.Column="2"
                                 Margin="0,0,8,0"
                                 Padding="6,4"
                                 Style="{StaticResource DarkTb}"
                                 ToolTip="Сумма скидки, сом"/>
                        <Button Grid.Column="3"
                                Content="Применить"
                                Click="ApplyOrderDiscount_Click"
                                Padding="8,5"
                                Margin="0,0,6,0"
                                Cursor="Hand"
                                Background="#374151"
                                Foreground="#F3F4F6"
                                BorderBrush="#4B5563"
                                BorderThickness="1"/>
                        <Button Grid.Column="4"
                                Content="Сброс"
                                Click="ClearOrderDiscount_Click"
                                Padding="8,5"
                                Cursor="Hand"
                                Background="#374151"
                                Foreground="#F3F4F6"
                                BorderBrush="#4B5563"
                                BorderThickness="1"/>
                    </Grid>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Штрихкод"
                               FontSize="11"
                               Foreground="#9CA3AF"
                               Margin="0,0,0,4"/>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="BarcodeBox"
                                 Grid.Column="0"
                                 Margin="0,0,8,0"
                                 Padding="8,6"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 Style="{StaticResource DarkTb}"
                                 KeyDown="BarcodeBox_KeyDown"/>
                        <Button x:Name="ScanBarcodeButton"
                                Grid.Column="1"
                                Content="Добавить"
                                Click="ScanBarcode_Click"
                                Padding="12,8"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                Background="#374151"
                                Foreground="#F3F4F6"
                                BorderBrush="#4B5563"
                                BorderThickness="1"/>
                    </Grid>
                    <TextBlock x:Name="CartMessageText"
                               DockPanel.Dock="Top"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Margin="0,0,0,8"
                               MinHeight="32"/>
                    <Border DockPanel.Dock="Bottom"
                            Background="#0F0F0F"
                            BorderBrush="#333333"
                            BorderThickness="0,1,0,0"
                            Padding="0,10,0,0"
                            Margin="0,8,0,0">
                        <TextBlock x:Name="CartTotalText"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#F9FAFB"
                                   HorizontalAlignment="Right"/>
                    </Border>
                    <ListView x:Name="CartListView"
                              ItemsSource="{Binding CartLines}"
                              BorderThickness="0"
                              Background="#1A1A1A"
                              Foreground="#F3F4F6"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type pos:CartLineRow}">
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#F3F4F6"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SubLine}"
                                                   FontSize="11"
                                                   Foreground="#9CA3AF"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding LineTotal}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Margin="8,0,8,0"
                                                VerticalAlignment="Center">
                                        <Button Content="Взвесить"
                                                Padding="10,6"
                                                FontSize="12"
                                                Click="CartWeigh_Click"
                                                Cursor="Hand"
                                                ToolTip="Указать вес с весов или вручную"
                                                Visibility="{Binding WeighedLine, Converter={StaticResource BoolToVis}}"/>
                                        <Button Content="Удалить"
                                                Padding="10,6"
                                                Margin="0,4,0,0"
                                                FontSize="12"
                                                Click="CartLineDelete_Click"
                                                Cursor="Hand"
                                                ToolTip="Убрать позицию из чека"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2"
                                                Orientation="Vertical"
                                                VerticalAlignment="Center">
                                        <Button Content="−"
                                                Width="36"
                                                Padding="0,6"
                                                Margin="0,0,0,4"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Click="CartQtyMinus_Click"
                                                Cursor="Hand"
                                                ToolTip="Меньше (100 г или −1 шт)"/>
                                        <Button Content="+"
                                                Width="36"
                                                Padding="0,6"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Click="CartQtyPlus_Click"
                                                Cursor="Hand"
                                                ToolTip="Больше (+100 г или +1 шт)"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Border>

            <Border x:Name="ToastPanel"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Panel.ZIndex="50"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16"
                    Background="#1F2937"
                    CornerRadius="8"
                    Padding="16,10"
                    Visibility="Collapsed"
                    MaxWidth="720">
                <TextBlock x:Name="ToastText"
                           Foreground="White"
                           TextWrapping="Wrap"
                           FontSize="13"/>
            </Border>
        </Grid>
    </Grid>
</Window>
