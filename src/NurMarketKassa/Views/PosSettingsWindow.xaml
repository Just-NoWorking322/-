<Window x:Class="NurMarketKassa.Views.PosSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки кассы"
        Height="620"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>
            <TextBlock Text="Весы (COM)"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>
            <CheckBox x:Name="ScaleEnabledCheck"
                      Content="Включить опрос весов"
                      Margin="0,0,0,8"/>
            <TextBlock Text="COM-порт" FontSize="12" Foreground="#374151"/>
            <ComboBox x:Name="ScaleComCombo"
                      IsEditable="True"
                      Margin="0,4,0,8"
                      Padding="8,6"/>
            <TextBlock Text="Скорость (baud)" FontSize="12" Foreground="#374151"/>
            <TextBox x:Name="ScaleBaudBox"
                     Margin="0,4,0,8"
                     Padding="8,6"/>
            <TextBlock Text="Запрос веса (hex, опционально), напр. 05"
                       FontSize="12"
                       Foreground="#374151"/>
            <TextBox x:Name="ScaleHexBox"
                     Margin="0,4,0,8"
                     Padding="8,6"/>
            <TextBlock Text="Повтор запроса (мс, 0 = не слать)"
                       FontSize="12"
                       Foreground="#374151"/>
            <TextBox x:Name="ScalePollBox"
                     Margin="0,4,0,16"
                     Padding="8,6"/>

            <TextBlock Text="Термопринтер (LPT / ESC-POS)"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,8,0,8"/>
            <CheckBox x:Name="ReceiptEnabledCheck"
                      Content="Печатать чек при оплате (если отмечено в диалоге)"
                      Margin="0,0,0,8"/>
            <TextBlock Text="LPT-порт или путь" FontSize="12" Foreground="#374151"/>
            <TextBox x:Name="ReceiptLptBox"
                     Margin="0,4,0,8"
                     Padding="8,6"/>
            <TextBlock Text="Кодировка текста" FontSize="12" Foreground="#374151"/>
            <ComboBox x:Name="ReceiptEncCombo"
                      Margin="0,4,0,8"
                      Padding="8,6">
                <ComboBoxItem Content="cp866 — кириллица DOS/OEM" Tag="cp866"/>
                <ComboBoxItem Content="cp1251 / windows-1251" Tag="cp1251"/>
                <ComboBoxItem Content="wpc1251 (слот 46)" Tag="wpc1251"/>
            </ComboBox>
            <TextBlock Text="Таблица ESC t (как в PRINTER_EXE_CHAIN: 17 / 46 / 73 или авто)"
                       FontSize="12"
                       Foreground="#374151"/>
            <ComboBox x:Name="ReceiptTableCombo"
                      Margin="0,4,0,8"
                      Padding="8,6">
                <ComboBoxItem Content="Авто (по кодировке: 866→17, 1251→46)" Tag=""/>
                <ComboBoxItem Content="17 — CP866 / OEM" Tag="17"/>
                <ComboBoxItem Content="46 — CP1251 / WPC1251 (Cashino EP-200)" Tag="46"/>
                <ComboBoxItem Content="73" Tag="73"/>
            </ComboBox>
            <TextBlock Text="ESC R (0–255, пусто = не слать)"
                       FontSize="12"
                       Foreground="#374151"/>
            <TextBox x:Name="ReceiptEscRBox"
                     Margin="0,4,0,8"
                     Padding="8,6"/>
            <TextBlock Text="Повторы печати при сбое" FontSize="12" Foreground="#374151"/>
            <TextBox x:Name="ReceiptRetryBox"
                     Margin="0,4,0,16"
                     Padding="8,6"/>

            <TextBlock Text="Экран и автозагрузка"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,8,0,8"/>
            <CheckBox x:Name="FullscreenCheck"
                      Content="Полноэкранный режим (без рамки, на весь экран)"
                      Margin="0,0,0,8"/>
            <CheckBox x:Name="AutostartCheck"
                      Content="Запускать вместе с Windows"
                      Margin="0,0,0,16"/>

            <TextBlock Text="Настройки сохраняются в %AppData%\NurMarketKassa\"
                       FontSize="11"
                       Foreground="#6B7280"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена"
                        Click="Cancel_Click"
                        Padding="14,8"
                        Margin="0,0,8,0"
                        MinWidth="100"
                        Cursor="Hand"/>
                <Button Content="Сохранить"
                        Click="Save_Click"
                        Padding="14,8"
                        MinWidth="120"
                        FontWeight="SemiBold"
                        Background="#F7D617"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
