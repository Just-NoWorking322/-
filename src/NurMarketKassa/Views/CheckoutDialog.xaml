<Window x:Class="NurMarketKassa.Views.CheckoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оплата"
        Width="400" Height="Auto" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <StackPanel Margin="20">
        <TextBlock x:Name="TotalLabel"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#111827"
                   Margin="0,0,0,12"/>
        <TextBlock Text="Способ оплаты" FontSize="12" Foreground="#6B7280" Margin="0,0,0,6"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="RbCash"
                         Content="Наличные"
                         GroupName="Pay"
                         IsChecked="True"
                         Margin="0,0,16,0"
                         Checked="PayMethod_Changed"/>
            <RadioButton x:Name="RbTransfer"
                         Content="Безнал"
                         GroupName="Pay"
                         Checked="PayMethod_Changed"/>
        </StackPanel>
        <TextBlock Text="Получено наличными" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
        <TextBox x:Name="CashReceivedBox"
                 Padding="8,6"
                 FontSize="14"
                 Margin="0,0,0,12"/>
        <CheckBox x:Name="PrintReceiptCheck"
                  Content="Чек: print_receipt в API + печать на LPT (если ReceiptPrinter.Enabled в appsettings)"
                  FontSize="12"
                  Margin="0,0,0,12"/>
        <TextBlock x:Name="ErrorText"
                   Foreground="#B45309"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Margin="0,0,0,12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена"
                    IsCancel="True"
                    Padding="14,8"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Оплатить"
                    IsDefault="True"
                    Padding="14,8"
                    FontWeight="SemiBold"
                    Background="#F7D617"
                    BorderThickness="0"
                    Click="Pay_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
