<Window x:Class="NurMarketKassa.Views.OpenShiftDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Открыть смену"
        Height="200" Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <StackPanel Margin="20">
        <TextBlock Text="Сумма в кассе на открытие (opening_cash)" FontSize="12" Foreground="#374151" Margin="0,0,0,6"/>
        <TextBox x:Name="OpeningCashBox"
                 Text="0.00"
                 Padding="8,6"
                 FontSize="14"
                 Margin="0,0,0,20"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена"
                    IsCancel="True"
                    Padding="14,8"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Открыть"
                    IsDefault="True"
                    Padding="14,8"
                    FontWeight="SemiBold"
                    Background="#F7D617"
                    BorderThickness="0"
                    Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
