<Window x:Class="NurMarketKassa.Views.WeighedProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Взвесить товар"
        Width="380"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F9FAFB">
    <Border Padding="20" Background="White" Margin="12">
        <StackPanel>
            <TextBlock x:Name="TitleBlock"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#111827"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="PriceBlock"
                       FontSize="12"
                       Foreground="#6B7280"
                       Margin="0,8,0,0"/>
            <TextBlock Text="На весах сейчас"
                       FontSize="11"
                       Foreground="#6B7280"
                       Margin="0,14,0,4"/>
            <TextBlock x:Name="LiveScaleText"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#111827"
                       Text="—"/>
            <TextBlock Text="Вес, кг"
                       FontSize="11"
                       Foreground="#374151"
                       Margin="0,12,0,4"/>
            <TextBox x:Name="WeightBox"
                     Padding="8,6"
                     FontSize="15"
                     GotFocus="WeightBox_GotFocus"
                     KeyDown="WeightBox_KeyDown"/>
            <Button Content="Взвесить"
                    Margin="0,10,0,0"
                    Padding="10,6"
                    HorizontalAlignment="Left"
                    Click="FromScale_Click"
                    Cursor="Hand"
                    ToolTip="Подставить текущий вес с COM-весов"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="Отмена"
                        Padding="14,8"
                        Margin="0,0,8,0"
                        Click="Cancel_Click"
                        Cursor="Hand"/>
                <Button x:Name="OkButton"
                        Content="В чек"
                        Padding="14,8"
                        FontWeight="SemiBold"
                        Background="#F7D617"
                        BorderThickness="0"
                        Click="Ok_Click"
                        Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
