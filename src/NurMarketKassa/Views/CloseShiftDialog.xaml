<Window x:Class="NurMarketKassa.Views.CloseShiftDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Закрыть смену"
        Height="220" Width="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <StackPanel Margin="20">
        <TextBlock Text="Остаток в кассе при закрытии (closing_cash), можно оставить пустым"
                   FontSize="12"
                   Foreground="#374151"
                   TextWrapping="Wrap"
                   Margin="0,0,0,6"/>
        <TextBox x:Name="ClosingCashBox"
                 Padding="8,6"
                 FontSize="14"
                 Margin="0,0,0,20"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена"
                    IsCancel="True"
                    Padding="14,8"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Закрыть смену"
                    IsDefault="True"
                    Padding="14,8"
                    FontWeight="SemiBold"
                    Background="#F3F4F6"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
